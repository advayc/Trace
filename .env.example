# Client-safe — Expo bundles EXPO_PUBLIC_* into the app
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY

# Google Sign-In client IDs from Google Cloud Console (client-safe)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Server-side / MCP / CLI only — never commit real values
SUPABASE_PROJECT_ID=your_project_ref
SUPABASE_DB_PASSWORD=your_database_password

# Admin login (server-side record only — never referenced by app code)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=generate_a_strong_password
