{
  "expo": {
    "name": "Trace",
    "slug": "trace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/trace-icon.png",
    "scheme": "trace",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0C0E12",
    "ios": {
      "bundleIdentifier": "com.traceexplore.app",
      "icon": "./assets/images/trace-icon.png",
      "buildNumber": "2",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleIconName": "AppIcon",
        "NSLocationWhenInUseUsageDescription": "Trace reveals map tiles as you walk. Your precise location stays on your device.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Keep revealing tiles when the screen is locked during a walk. Optional, off by default.",
        "NSContactsUsageDescription": "Trace can suggest contacts so you can invite friends to the leaderboard.",
        "NSHealthShareUsageDescription": "Trace can read step counts to enrich your activity stats.",
        "NSHealthUpdateUsageDescription": "Trace can save completed walks and runs to Apple Health.",
        "UIBackgroundModes": [
          "location"
        ],
        "NSSupportsLiveActivities": true,
        "LSApplicationQueriesSchemes": [
          "sms"
        ]
      },
      "appleTeamId": "5FU387AV9F"
    },
    "android": {
      "package": "com.traceexplore.app",
      "adaptiveIcon": {
        "backgroundColor": "#0C0E12",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0E12",
          "image": "./assets/images/trace-splash.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Trace can suggest contacts so you can invite friends to the leaderboard."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Trace reveals map tiles as you walk. Your precise location stays on your device.",
          "locationAlwaysAndWhenInUsePermission": "Keep revealing tiles when the screen is locked during a walk. Optional, off by default.",
          "isIOSBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.418709591835-9n42v8e78pkb6fid87a5kdrka4vcbjqb"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "RecaptchaInterop",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      "expo-sharing",
      [
        "@kayzmann/expo-healthkit",
        {
          "healthShareUsageDescription": "Trace can read step counts, calories, and heart rate to enrich your activity stats.",
          "healthUpdateUsageDescription": "Trace can save completed walks and runs to Apple Health."
        }
      ],
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.traceexplore.app",
          "enablePushNotifications": false,
          "widgets": [
            {
              "name": "TraceWalkActivity",
              "displayName": "Walk Activity",
              "description": "Live stats while you walk or run",
              "supportedFamilies": ["systemSmall"]
            }
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/trace-icon.png",
          "color": "#E8A04C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
